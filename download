from schemas import CurrentStudy, Study
from model import predict_pair, score_pair


def cur(desc: str) -> CurrentStudy:
    return CurrentStudy(study_id="c", study_description=desc, study_date="2026-03-08")


def prior(desc: str, date: str = "2025-03-08") -> Study:
    return Study(study_id="p", study_description=desc, study_date=date)


def test_same_body_and_modality_is_relevant():
    assert predict_pair(cur("CT HEAD WITHOUT CONTRAST"), prior("CT HEAD WITHOUT CONTRAST")) is True


def test_unrelated_body_region_is_not_relevant():
    assert predict_pair(cur("MRI BRAIN WITHOUT CONTRAST"), prior("XR ANKLE 3 VIEWS")) is False


def test_ct_head_and_mri_brain_stroke_can_be_relevant():
    assert predict_pair(cur("MRI BRAIN STROKE LIMITED WITHOUT CONTRAST"), prior("CT HEAD WITHOUT CONTRAST")) is True


def test_old_unrelated_prior_has_low_score():
    assert score_pair(cur("CT CHEST WITH CONTRAST"), prior("XR HAND", "2010-01-01")) < 0
